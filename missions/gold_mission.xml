<?xml version="1.0" encoding="UTF-8"?>

<Mission xmlns="http://ProjectMalmo.microsoft.com"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <About>
    <Summary>Simple Flat RL World</Summary>
  </About>

  <ServerSection>

    <ServerInitialConditions>
      <Time>
        <StartTime>1000</StartTime>
        <AllowPassageOfTime>false</AllowPassageOfTime>
      </Time>
      <Weather>clear</Weather>
    </ServerInitialConditions>

    <ServerHandlers>

      <!-- Flat ground -->
      <FlatWorldGenerator generatorString="3;7,2;1;"/>

      <!-- Build simple layout -->
      <DrawingDecorator>

        <!-- Walls -->
        <DrawCuboid x1="-5" y1="0" z1="-5"
                    x2="5" y2="5" z2="-5"
                    type="stone"/>

        <DrawCuboid x1="-5" y1="0" z1="5"
                    x2="5" y2="5" z2="5"
                    type="stone"/>

        <DrawCuboid x1="-5" y1="0" z1="-5"
                    x2="-5" y2="5" z2="5"
                    type="stone"/>

        <DrawCuboid x1="5" y1="0" z1="-5"
                    x2="5" y2="5" z2="5"
                    type="stone"/>

        <!-- Goal -->
        <DrawBlock x="2" y="2" z="2" type="gold_block"/>

        <!-- Hazard -->
        <DrawBlock x="-2" y="227" z="-2" type="lava"/>

      </DrawingDecorator>

      <ServerQuitFromTimeUp timeLimitMs="100000"/>
      <ServerQuitWhenAnyAgentFinishes/>

    </ServerHandlers>

  </ServerSection>

  <AgentSection mode="Survival">

    <Name>Agent</Name>

    <AgentStart>
      <Placement x="0.5" y="2.5" z="-3.5"/>
    </AgentStart>

    <AgentHandlers>

      <!-- IMPORTANT: NO VIDEO OBSERVATION -->

      <DiscreteMovementCommands>
         <ModifierList type="allow-list">
            <command>move</command>
            <command>turn</command>
         </ModifierList>
      </DiscreteMovementCommands>

      <ObservationFromFullStats/>

      <!-- Optional grid observation for RL -->
      <ObservationFromGrid>
        <Grid absoluteCoords="false" name="grid">
          <min x="-4" y="-1" z="-4"/>
          <max x="4" y="1" z="4"/>
        </Grid>
      </ObservationFromGrid>
      <VideoProducer want_depth="false">
         <Width>800</Width>
         <Height>600</Height>
      </VideoProducer>

      <!-- Episode ends on success/failure -->
      <AgentQuitFromTouchingBlockType>
        <Block type="gold_block"/>
        <Block type="lava"/>
      </AgentQuitFromTouchingBlockType>


      <RewardForTouchingBlockType>
        <Block reward="100" type="gold_block"/>
        <Block reward="-100" type="lava"/>
      </RewardForTouchingBlockType>
    </AgentHandlers>

  </AgentSection>

</Mission>